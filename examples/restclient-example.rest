# Restclient 与 Cookie 集成示例
#
# 本示例展示如何从 Chrome 自动获取 Cookie 并注入到 HTTP 请求中。
# 需要先安装 cookie-cli 并配置 cookie.el。

# 方法一：使用 cookie.el 提供的语法糖
# 在 Emacs 中加载 cookie.el 后，可以使用以下语法：
# {{cookie:domain}} 或 {{cookie:domain name}}

# 假设我们的云端服务域名是 api.example.com
# 认证 Token 存储在名为 "auth_token" 的 Cookie 中

# 定义变量，从 Chrome 获取 Cookie 值
:token = {{cookie:api.example.com auth_token}}

# 使用变量发起请求
GET https://api.example.com/user/profile
Authorization: Bearer :token
Content-Type: application/json

###

# 方法二：直接使用 shell 命令获取 Cookie 值
# restclient.el 支持通过 shell 命令获取变量值
:session = {{(shell-command-to-string "cookie-cli get -domain api.example.com -name sessionid")}}

POST https://api.example.com/data
Content-Type: application/json
Cookie: session=:session

{
  "action": "test"
}

###

# 方法三：使用 cookie.el 的辅助函数
# 在 Emacs Lisp 中，可以先获取 Cookie 值，再设置为变量
# (setq token (cookie-get-value "api.example.com" "auth_token"))
# 然后在 restclient 中使用 :token 变量

# 获取多个 Cookie
GET https://api.example.com/items
Authorization: Bearer {{cookie:api.example.com auth_token}}
Cookie: csrftoken={{cookie:api.example.com csrftoken}}; session={{cookie:api.example.com sessionid}}

###

# 错误处理示例
# 如果 Cookie 不存在或获取失败，可以设置默认值
# 注意：这需要自定义 Emacs Lisp 函数

# 假设我们有一个安全的获取函数
:maybe_token = {{(condition-case nil (cookie-get-value "api.example.com" "auth_token") (error "INVALID_TOKEN"))}}

GET https://api.example.com/test
Authorization: Bearer :maybe_token

###

# 多环境配置示例
# 通过环境变量或配置文件区分不同环境的域名
:dev_token = {{cookie:dev.api.example.com auth_token}}
:prod_token = {{cookie:api.example.com auth_token}}

# 开发环境请求
GET https://dev.api.example.com/user
Authorization: Bearer :dev_token

# 生产环境请求（注释掉开发环境请求即可切换）
# GET https://api.example.com/user
# Authorization: Bearer :prod_token
